+  const extra = (process.env.WAITLIST_ALLOWED_ORIGINS ?? "")
+    .split(",")
+    .map(normalizeOrigin)
+    .filter(Boolean);
+  return [...STATIC_ALLOWED_ORIGINS, ...extra];
+}
+
+function isAllowedOrigin(origin: string): boolean {
+  return allowedOrigins().includes(normalizeOrigin(origin));
+}
