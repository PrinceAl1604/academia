# ─── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Domains (two-domain split) ──────────────────────────────
# The marketing landing and the product app run on two hostnames off the
# same deployment, routed by Host header in src/middleware.ts:
#   • SITE_URL → landing / marketing (public, indexable)
#   • APP_URL  → the product app (auth, dashboard, courses, admin)
# Emails + payment/auth redirects use APP_URL; SEO/OG/sitemap use SITE_URL.
# Any host matching neither (Vercel preview, localhost) stays single-domain.
NEXT_PUBLIC_SITE_URL=https://programme.workshop-visible.com
NEXT_PUBLIC_APP_URL=https://app.workshop-visible.com

# ─── Resend (Email) ─────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=Brightroots <noreply@yourdomain.com>

# ─── Zapier (waitlist email via Gmail + lead capture) ───────
# Optional. When set, a waitlist signup POSTs the rendered welcome email to
# this Zapier "Catch Hook" instead of sending through Resend. The Zap then
# files the lead (e.g. Google Sheets) and sends the email from Google
# Workspace (Gmail). Create one at: Zapier → Webhooks by Zapier → Catch Hook.
# Leave empty to keep sending the waitlist email through Resend.
ZAPIER_WAITLIST_HOOK_URL=

# ─── Chariow (Payment) ──────────────────────────────────────
# Your Chariow product page URL for licence key purchases
NEXT_PUBLIC_CHARIOW_PRODUCT_URL=https://yourshop.mychariow.shop/prd_xxxxxx

# ─── Legacy (not actively used — kept for reference) ────────
# MONEROO_SECRET_KEY=
# NEXT_PUBLIC_MONETBIL_SERVICE_KEY=
